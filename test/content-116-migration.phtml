/**
 * Форматирует num_investika как INVXXXXX.
 * Если поле уже содержит префикс INV — сохраняет как есть (upper).
 */
function formatInvestikaCode($num): string
{
    if (!$num) return '—';
    $s = trim((string) $num);
    if ($s === '') return '—';
    if (mb_strtoupper(mb_substr($s, 0, 3)) === 'INV') return mb_strtoupper($s);
    return 'INV' . $s;
}

/**
 * Разбирает юридический подтип из наименования.
 * org_type в UMI не существует — парсинг из basicname/origname.
 */
function parseLegalSubtype($basicname, $origname = ''): string
{
    $name = (string) $basicname . ' ' . (string) $origname;
    if (mb_strpos($name, 'ПАО') !== false) return 'ПАО';
    if (mb_strpos($name, 'АО')  !== false) return 'АО';
    if (mb_strpos($name, 'ООО') !== false) return 'ООО';
    return 'ЮЛ';
}

/** Метка статуса комплаенса из status_klienta. */
function mapStatusLabel($code): string
{
    $map = ['5' => 'Пройден', '3' => 'На проверке', '4' => 'На доработке', '-1' => 'Заблокирован'];
    return $map[(string) $code] ?? '—';
}

/** CSS-модификатор бейджа статуса. */
function mapStatusBadgeClass($code): string
{
    $map = ['5' => 'success', '3' => 'info', '4' => 'warning', '-1' => 'danger'];
    return $map[(string) $code] ?? 'muted';
}

/** data-filter-compliance-status значение. */
function mapStatusFilterValue($code): string
{
    $map = ['5' => 'approved', '3' => 'pending-review', '4' => 'rework', '-1' => 'blocked'];
    return $map[(string) $code] ?? 'unknown';
}

/**
 * Метка резидентства из isrezident.
 * ФЛ: isrezident=true → «Гражданин РФ», false → «Иностранный гражданин».
 * ЮЛ: isrezident=true → «Российское ЮЛ», false → «Иностранное ЮЛ».
 */
function mapResidencyLabel($isrezident, string $entityType): string
{
    if ($entityType === 'firm') {
        return $isrezident ? 'Российское ЮЛ' : 'Иностранное ЮЛ';
    }
    return $isrezident ? 'Гражданин РФ' : 'Иностранный гражданин';
}

/** CSS-модификатор бейджа резидентства. */
function mapResidencyBadgeClass($isrezident): string
{
    return $isrezident ? 'success' : 'warning';
}

/** data-filter-residency значение. */
function mapResidencyFilterValue($isrezident): string
{
    return $isrezident ? 'resident' : 'non-resident';
}

/**
 * data-filter-client-type значение.
 * ИП: TODO — нет подтверждённого источника ОГРНИП / отдельного шаблона в UMI.
 */
function mapClientTypeFilterValue(string $entityType, string $subtype): string
{
    if ($entityType === 'phys') return 'person';
    $subtypeMap = ['ООО' => 'legal llc', 'АО' => 'legal ao', 'ПАО' => 'legal pao'];
    return $subtypeMap[$subtype] ?? 'legal';
}

/** Метка типа клиента для отображения. */
function mapClientTypeLabel(string $entityType, string $subtype): string
{
    if ($entityType === 'phys') return 'Физ. лицо';
    if ($subtype === 'ЮЛ') return 'Юр. лицо';
    return $subtype;
}

/**
 * Маппинг risklevel (guide ID 145).
 * initial → КНУР, low → КОУР, medium → КСУР, high → КПУР.
 */
function mapRiskLevelLabel($value): string
{
    $map = [
        'initial' => 'КНУР',
        'low'     => 'КОУР',
        'medium'  => 'КСУР',
        'high'    => 'КПУР',
    ];
    return $map[(string) $value] ?? '—';
}

