function normForLog($v): string
{
    if ($v === null)    return '';
    if (is_bool($v))   return $v ? '1' : '0';
    if (is_scalar($v)) return (string) $v;
    return json_encode($v, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES);
}

function trackUmiSet($object, array &$fieldsLog, string $field, $newValue, string $source = 'front_compliance'): bool
{
    $oldValue = $object->getValue($field);
    $oldNorm  = normForLog($oldValue);
    $newNorm  = normForLog($newValue);
    $changed  = ($oldNorm !== $newNorm);

    if (!$changed) {
        $fieldsLog[] = ['field' => $field, 'value' => $newNorm, 'source' => $source, 'changed' => false, 'meta' => ['op' => 'set', 'prev' => $oldNorm]];
        return false;
    }
    try {
        $object->setValue($field, $newValue);
        $fieldsLog[] = ['field' => $field, 'value' => $newNorm, 'source' => $source, 'changed' => true, 'meta' => ['op' => 'set', 'prev' => $oldNorm]];
        return true;
    } catch (Throwable $e) {
        $fieldsLog[] = ['field' => $field, 'value' => $newNorm, 'source' => $source, 'changed' => false, 'meta' => ['op' => 'set', 'prev' => $oldNorm, 'error' => $e->getMessage()]];
        return false;
    }
}

