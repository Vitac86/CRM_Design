foreach ($allStatuses as $statusCode) {
    $phys = getUserIdByStatus($statusCode);
    if ($phys && $phys->length() > 0) {
        foreach ($phys as $obj) {
            $surname    = $obj->getValue('surname');
            $namecl     = $obj->getValue('namecl');
            $patronymic = $obj->getValue('patronymic');
            $fullName   = trim("$surname $namecl $patronymic") ?: '—';
            $isrezident = (bool) $obj->getValue('isrezident');
            $numInv     = $obj->getValue('num_investika');
            $items[] = [
                'type'                => 'phys',
                'hash'                => (string) $obj->getValue('hash'),
                'code'                => formatInvestikaCode($numInv),
                'name'                => $fullName,
                'inn'                 => (string) $obj->getValue('inn'),
                'subtype'             => '',
                'type_label'          => 'Физ. лицо',
                'type_filter'         => 'person',
                // ФЛ: isrezident = гражданство РФ, не налоговое резидентство
                'residency_label'     => mapResidencyLabel($isrezident, 'phys'),
                'residency_badge'     => mapResidencyBadgeClass($isrezident),
                'residency_filter'    => mapResidencyFilterValue($isrezident),
                'status_raw'          => $statusCode,
                'status_label'        => mapStatusLabel($statusCode),
                'status_badge'        => mapStatusBadgeClass($statusCode),
                'status_filter'       => mapStatusFilterValue($statusCode),
                // TODO: «Полный комплект документов» — нет подтверждённого поля в UMI.
                'docs_complete_todo'  => true,
            ];
        }
    }
}

