function addChatLines($date)
{
    if (!is_array($date))
        return "";
    if (count($date) < 1)
        return "";

    $print_flag = false;
    $print_info = '<div class="uk-panel uk-panel-scrollable">';
    $print_info .= '<dl class="uk-description-list uk-description-list-divider">';

    foreach ($date as $infline) {
        $inf = explode("|", $infline);
        if (count($inf) < 4)
            continue;

        $print_info .= '<dt><div class="uk-width-expand">
                                <h4 class="uk-comment-title uk-margin-remove">' . htmlspecialchars($inf[2]) . '</h4>
                                <p class="uk-comment-meta uk-margin-remove-top">' . htmlspecialchars($inf[1]) . '</p>
                            </div></dt>
                        <dd>' . htmlspecialchars($inf[3]) . '</dd>';
        $print_flag = true;
    }
    $print_info .= '</dl></div>';
    return $print_flag ? $print_info : "";
}

/**
 * Безопасное преобразование значения для вывода в таблице
 */
function safeValue($val)
{
    if (is_null($val))
        return '';
    if (is_scalar($val))
        return htmlspecialchars((string) $val, ENT_QUOTES, 'UTF-8');
    if (is_array($val)) {
        $parts = [];
        array_walk_recursive($val, function ($item) use (&$parts) {
            $parts[] = htmlspecialchars((string) $item, ENT_QUOTES, 'UTF-8');
        });
        return implode(' ', $parts);
    }
    if (is_object($val) && method_exists($val, '__toString')) {
        return htmlspecialchars((string) $val, ENT_QUOTES, 'UTF-8');
    }
    return htmlspecialchars(print_r($val, true), ENT_QUOTES, 'UTF-8');
}
