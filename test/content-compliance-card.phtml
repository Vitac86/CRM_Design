/** Форматирует историю komplajns_zamechaniya (pipe-delimited) в массив записей. */
function cardParseRemarksHistory($raw): array
{
    if (!$raw) return [];
    $entries = explode('_|||_', trim((string) $raw));
    $result  = [];
    foreach ($entries as $entry) {
        $entry = ltrim($entry, '|');
        if ($entry === '') continue;
        $parts = explode('|', $entry, 4);
        $result[] = [
            'date'    => isset($parts[0]) ? htmlspecialchars(trim($parts[0]), ENT_QUOTES, 'UTF-8') : '',
            'user'    => isset($parts[1]) ? htmlspecialchars(trim($parts[1]), ENT_QUOTES, 'UTF-8') : '',
            'comment' => isset($parts[2]) ? htmlspecialchars(trim($parts[2]), ENT_QUOTES, 'UTF-8') : '',
        ];
    }
    return array_filter($result, fn($r) => $r['comment'] !== '');
}

/** Строит адресную строку из полей объекта. */
function cardBuildAddress($obj): string
{
    $parts = [];
    $index = trim((string) $obj->getValue('index'));
    if ($index) $parts[] = $index;
    $country = trim((string) $obj->getValue('country'));
    if ($country) $parts[] = $country;
    $region = trim((string) $obj->getValue('region'));
    if ($region) $parts[] = $region;
    $city = trim((string) $obj->getValue('city'));
    if ($city) $parts[] = $city;
    $settlement = trim((string) $obj->getValue('settlement'));
    if ($settlement) $parts[] = $settlement;
    $street = trim((string) $obj->getValue('street'));
    if ($street) $parts[] = $street;
    $house = trim((string) $obj->getValue('house'));
    if ($house) $parts[] = 'д. ' . $house;
    $corps = trim((string) $obj->getValue('corps'));
    if ($corps) $parts[] = 'корп. ' . $corps;
    $flat = trim((string) $obj->getValue('flat'));
    if ($flat) $parts[] = 'кв./оф. ' . $flat;
    return implode(', ', $parts) ?: '—';
}

