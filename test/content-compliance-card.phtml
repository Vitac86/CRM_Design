function cardFormatInvestikaCode($num): string
{
    if (!$num) return '—';
    $s = trim((string) $num);
    if ($s === '') return '—';
    if (mb_strtoupper(mb_substr($s, 0, 3)) === 'INV') return mb_strtoupper($s);
    return 'INV' . $s;
}

/**
 * Парсинг юридического подтипа из наименования.
 * org_type в UMI не существует — парсинг из basicname/origname.
 */
function cardParseLegalSubtype($basicname, $origname = ''): string
{
    $name = (string) $basicname . ' ' . (string) $origname;
    if (mb_strpos($name, 'ПАО') !== false) return 'ПАО';
    if (mb_strpos($name, 'АО')  !== false) return 'АО';
    if (mb_strpos($name, 'ООО') !== false) return 'ООО';
    return 'ЮЛ';
}

